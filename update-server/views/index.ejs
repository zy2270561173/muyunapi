<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MuYunAPI 更新管理</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --surface3: #2a2f47;
      --border: rgba(255,255,255,0.07);
      --border2: rgba(255,255,255,0.12);
      --accent: #e99312;
      --accent-dim: rgba(233,147,18,0.14);
      --accent-hover: #f5a832;
      --accent-glow: rgba(233,147,18,0.25);
      --text: #e8eaf0;
      --text-muted: #7a7f9a;
      --text-dim: #4a5070;
      --success: #22c55e;
      --success-dim: rgba(34,197,94,0.12);
      --danger: #f04040;
      --danger-dim: rgba(240,64,64,0.12);
      --warning: #f59e0b;
      --info: #3b82f6;
      --sidebar-w: 230px;
      --header-h: 60px;
      --radius: 12px;
      --radius-sm: 8px;
    }

    html, body { height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.5;
    }

    /* ─── Scrollbar ─── */
    ::-webkit-scrollbar { width: 5px; height: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 3px; }

    /* ─── Layout ─── */
    .layout { display: flex; min-height: 100vh; }

    /* ─── Sidebar ─── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--surface);
      border-right: 1px solid var(--border);
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 200;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
    }

    .sidebar-logo {
      height: var(--header-h);
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 18px;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .sidebar-logo .logo-icon {
      width: 32px; height: 32px;
      background: var(--accent-dim);
      border: 1px solid rgba(233,147,18,0.25);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }
    .sidebar-logo .logo-text {
      font-size: 16px;
      font-weight: 700;
      white-space: nowrap;
    }
    .sidebar-logo .logo-text span { color: var(--accent); }

    .sidebar-nav { flex: 1; padding: 10px 10px; overflow-y: auto; }
    .nav-group-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.8px;
      color: var(--text-dim);
      text-transform: uppercase;
      padding: 10px 10px 4px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: var(--radius-sm);
      color: var(--text-muted);
      text-decoration: none;
      font-size: 13.5px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 2px;
      user-select: none;
    }
    .nav-item:hover { color: var(--text); background: rgba(255,255,255,0.05); }
    .nav-item.active {
      color: var(--accent);
      background: var(--accent-dim);
    }
    .nav-item .nav-icon { font-size: 15px; width: 18px; text-align: center; flex-shrink: 0; }
    .nav-item .nav-badge {
      margin-left: auto;
      background: var(--accent);
      color: #fff;
      font-size: 10px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 10px;
    }

    .sidebar-footer {
      padding: 12px;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }
    .sidebar-user {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      border-radius: var(--radius-sm);
      background: var(--surface2);
    }
    .sidebar-user .avatar {
      width: 30px; height: 30px;
      background: var(--accent-dim);
      border: 1px solid rgba(233,147,18,0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      flex-shrink: 0;
    }
    .sidebar-user .user-info { flex: 1; min-width: 0; }
    .sidebar-user .user-name { font-size: 13px; font-weight: 600; truncate: ellipsis; white-space: nowrap; overflow: hidden; }
    .sidebar-user .user-role { font-size: 11px; color: var(--text-muted); }
    .btn-logout-icon {
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 16px;
      cursor: pointer;
      padding: 4px;
      border-radius: 6px;
      transition: color 0.2s, background 0.2s;
      flex-shrink: 0;
    }
    .btn-logout-icon:hover { color: var(--danger); background: var(--danger-dim); }

    /* ─── Main ─── */
    .main {
      margin-left: var(--sidebar-w);
      flex: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ─── Header ─── */
    .header {
      height: var(--header-h);
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 24px;
      gap: 12px;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 20px;
      cursor: pointer;
      padding: 4px;
    }
    .page-title {
      font-size: 16px;
      font-weight: 600;
    }
    .header-spacer { flex: 1; }
    .header-server-url {
      font-size: 12px;
      color: var(--text-muted);
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 4px 10px;
      font-family: 'Consolas', 'Monaco', monospace;
      max-width: 260px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* ─── Content ─── */
    .content { padding: 24px; flex: 1; }

    /* ─── Stats Grid ─── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 22px;
    }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      transition: border-color 0.2s;
    }
    .stat-card:hover { border-color: var(--border2); }
    .stat-icon {
      width: 42px; height: 42px;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .stat-icon.orange { background: var(--accent-dim); }
    .stat-icon.green { background: var(--success-dim); }
    .stat-icon.blue { background: rgba(59,130,246,0.12); }
    .stat-icon.purple { background: rgba(139,92,246,0.12); }
    .stat-body .label { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
    .stat-body .value { font-size: 24px; font-weight: 700; }
    .stat-body .value.orange { color: var(--accent); }
    .stat-body .value.green { color: var(--success); }
    .stat-body .value.blue { color: var(--info); }
    .stat-body .value.purple { color: #a78bfa; }

    /* ─── Card ─── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      margin-bottom: 18px;
      overflow: hidden;
    }
    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
    }
    .card-title {
      font-size: 14px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-body { padding: 20px; }

    /* ─── API Info ─── */
    .api-info-block {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 14px 16px;
      font-size: 13px;
    }
    .api-info-block .method {
      display: inline-block;
      background: rgba(233,147,18,0.2);
      color: var(--accent);
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 11px;
      font-weight: 700;
      margin-right: 8px;
      font-family: monospace;
    }
    .api-info-block code {
      background: var(--surface3);
      color: var(--accent);
      border-radius: 4px;
      padding: 2px 7px;
      font-family: 'Consolas', 'Monaco', monospace;
      font-size: 12px;
      word-break: break-all;
    }
    .api-info-block .req-example {
      margin-top: 10px;
      background: var(--surface3);
      border-radius: var(--radius-sm);
      padding: 10px 12px;
      font-family: 'Consolas', 'Monaco', monospace;
      font-size: 12px;
      color: var(--text-muted);
      overflow-x: auto;
      white-space: pre;
    }

    /* ─── Table ─── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      padding: 11px 16px;
      text-align: left;
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
      letter-spacing: 0.4px;
      text-transform: uppercase;
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
      background: var(--surface2);
    }
    tbody td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
      font-size: 13.5px;
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: rgba(255,255,255,0.025); }

    /* ─── Badges / Tags ─── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 9px;
      border-radius: 20px;
      font-size: 11.5px;
      font-weight: 600;
    }
    .badge-stable { background: var(--success-dim); color: var(--success); }
    .badge-beta { background: rgba(245,158,11,0.12); color: var(--warning); }
    .badge-alpha { background: var(--danger-dim); color: var(--danger); }
    .badge-dev { background: rgba(59,130,246,0.12); color: var(--info); }
    .badge-active { background: var(--success-dim); color: var(--success); }
    .badge-inactive { background: rgba(255,255,255,0.05); color: var(--text-muted); }

    /* ─── Buttons ─── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border: none;
      border-radius: var(--radius-sm);
      font-size: 13.5px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .btn-primary {
      background: var(--accent);
      color: #fff;
    }
    .btn-primary:hover:not(:disabled) {
      background: var(--accent-hover);
      box-shadow: 0 4px 14px var(--accent-glow);
      transform: translateY(-1px);
    }
    .btn-sm { padding: 5px 12px; font-size: 12px; border-radius: 6px; }
    .btn-ghost {
      background: rgba(255,255,255,0.06);
      color: var(--text-muted);
      border: 1px solid var(--border);
    }
    .btn-ghost:hover:not(:disabled) { background: rgba(255,255,255,0.1); color: var(--text); }
    .btn-danger-ghost {
      background: none;
      color: var(--text-muted);
      border: none;
      padding: 4px 8px;
    }
    .btn-danger-ghost:hover { color: var(--danger); background: var(--danger-dim); }
    .btn-enable-ghost {
      background: none;
      color: var(--text-muted);
      border: none;
      padding: 4px 8px;
    }
    .btn-enable-ghost:hover { color: var(--success); background: var(--success-dim); }

    /* ─── Upload Area ─── */
    .upload-area {
      border: 2px dashed var(--border2);
      border-radius: var(--radius);
      padding: 36px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      margin-bottom: 20px;
    }
    .upload-area:hover,
    .upload-area.dragover {
      border-color: var(--accent);
      background: var(--accent-dim);
    }
    .upload-area .up-icon { font-size: 40px; margin-bottom: 10px; }
    .upload-area .up-title { font-size: 15px; font-weight: 600; margin-bottom: 5px; }
    .upload-area .up-hint { font-size: 12px; color: var(--text-muted); }
    .upload-area .file-chosen {
      margin-top: 10px;
      font-size: 13px;
      color: var(--accent);
      font-weight: 500;
    }

    /* ─── Form ─── */
    .form-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 16px;
    }
    .form-item label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: var(--text-muted);
      margin-bottom: 6px;
      letter-spacing: 0.3px;
    }
    .form-item input,
    .form-item select,
    .form-item textarea {
      width: 100%;
      padding: 9px 12px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      font-size: 13.5px;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      font-family: inherit;
    }
    .form-item input::placeholder,
    .form-item textarea::placeholder { color: var(--text-dim); }
    .form-item input:focus,
    .form-item select:focus,
    .form-item textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(233,147,18,0.1);
    }
    .form-item select option { background: var(--surface2); }
    .form-item textarea { resize: vertical; min-height: 70px; }
    .form-item .checkbox-label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      font-size: 13.5px;
      color: var(--text);
    }
    .form-item input[type="checkbox"] {
      width: 16px; height: 16px;
      accent-color: var(--accent);
      padding: 0;
    }

    /* ─── Progress ─── */
    .progress-wrap {
      height: 5px;
      background: var(--surface2);
      border-radius: 3px;
      overflow: hidden;
      margin-top: 14px;
      display: none;
    }
    .progress-wrap.show { display: block; }
    .progress-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 3px;
      transition: width 0.3s;
      width: 0%;
    }

    /* ─── Toast ─── */
    .toast-container {
      position: fixed;
      top: 16px; right: 16px;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .toast {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 10px;
      font-size: 13.5px;
      max-width: 340px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      animation: slideIn 0.25s ease;
      pointer-events: auto;
    }
    .toast-success { background: #0f2318; border: 1px solid rgba(34,197,94,0.25); color: var(--success); }
    .toast-error { background: #1e0f0f; border: 1px solid rgba(240,64,64,0.25); color: var(--danger); }
    .toast-info { background: #0f1a2e; border: 1px solid rgba(59,130,246,0.25); color: var(--info); }
    @keyframes slideIn {
      from { transform: translateX(40px); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }

    /* ─── Modal ─── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.65);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
      backdrop-filter: blur(2px);
    }
    .modal-overlay.show { display: flex; }
    .modal {
      background: var(--surface);
      border: 1px solid var(--border2);
      border-radius: var(--radius);
      padding: 28px;
      width: 440px;
      max-width: 90vw;
      box-shadow: 0 24px 80px rgba(0,0,0,0.6);
    }
    .modal h3 { font-size: 16px; margin-bottom: 10px; }
    .modal p { font-size: 13.5px; color: var(--text-muted); line-height: 1.6; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 10px; margin-top: 22px; }

    /* ─── Empty ─── */
    .empty-row td { text-align: center; padding: 40px !important; color: var(--text-dim) !important; }
    .empty-icon { font-size: 32px; margin-bottom: 8px; display: block; }

    /* ─── Page Sections ─── */
    .page-section { display: none; }
    .page-section.active { display: block; }

    /* ─── Version pill ─── */
    .version-pill {
      font-weight: 700;
      color: var(--accent);
      font-size: 13.5px;
    }

    /* ─── Responsive ─── */
    @media (max-width: 900px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); box-shadow: 0 0 0 100vw rgba(0,0,0,0.5); }
      .main { margin-left: 0; }
      .mobile-toggle { display: block; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .form-grid { grid-template-columns: 1fr; }
      .header-server-url { display: none; }
    }
    @media (max-width: 480px) {
      .stats-grid { grid-template-columns: 1fr; }
      .content { padding: 14px; }
    }
  </style>
</head>
<body>

<div class="layout">
  <!-- ─── Sidebar ─── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">☁️</div>
      <div class="logo-text">Mu<span>Yun</span>API</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-group-label">主菜单</div>
      <a class="nav-item active" onclick="switchPage('dashboard', this)">
        <span class="nav-icon">📊</span> 仪表盘
      </a>
      <a class="nav-item" onclick="switchPage('upload', this)">
        <span class="nav-icon">📤</span> 上传更新包
      </a>
      <a class="nav-item" onclick="switchPage('packages', this)">
        <span class="nav-icon">📦</span> 更新包管理
      </a>
      <a class="nav-item" onclick="switchPage('logs', this)">
        <span class="nav-icon">📋</span> 下载日志
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="avatar">👤</div>
        <div class="user-info">
          <div class="user-name" id="userDisplay">管理员</div>
          <div class="user-role">Administrator</div>
        </div>
        <button class="btn-logout-icon" onclick="logout()" title="退出登录">⏏</button>
      </div>
    </div>
  </aside>

  <!-- ─── Main ─── -->
  <div class="main">
    <!-- Header -->
    <header class="header">
      <button class="mobile-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
      <span class="page-title" id="pageTitle">仪表盘</span>
      <div class="header-spacer"></div>
      <span class="header-server-url" id="serverUrlDisplay"><%= serverUrl %></span>
    </header>

    <div class="content">

      <!-- ─── Dashboard ─── -->
      <div class="page-section active" id="page-dashboard">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-icon orange">📦</div>
            <div class="stat-body">
              <div class="label">更新包总数</div>
              <div class="value orange" id="statTotal">—</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon green">⬇️</div>
            <div class="stat-body">
              <div class="label">累计下载</div>
              <div class="value green" id="statDownloads">—</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon blue">📅</div>
            <div class="stat-body">
              <div class="label">近7天下载</div>
              <div class="value blue" id="statRecent">—</div>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-icon purple">🖥️</div>
            <div class="stat-body">
              <div class="label">平台分布</div>
              <div class="value purple" id="statPlatforms" style="font-size:14px;margin-top:2px;">—</div>
            </div>
          </div>
        </div>

        <!-- Check API -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">📡 客户端检查更新接口</div>
          </div>
          <div class="card-body">
            <div class="api-info-block">
              <span class="method">POST</span><code><%= serverUrl %>/api/packages/check</code>
              <div class="req-example">{"version":"1.2.2","platform":"win","arch":"x64","channel":"stable"}</div>
            </div>
          </div>
        </div>

        <!-- Recent Packages -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">🕐 最近上传</div>
            <button class="btn btn-ghost btn-sm" onclick="loadDashboard()">🔄 刷新</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>版本</th>
                  <th>平台 / 架构</th>
                  <th>通道</th>
                  <th>大小</th>
                  <th>下载次数</th>
                  <th>发布日期</th>
                  <th>状态</th>
                </tr>
              </thead>
              <tbody id="recentTable">
                <tr class="empty-row"><td colspan="7"><span class="empty-icon">⏳</span>加载中…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ─── Upload ─── -->
      <div class="page-section" id="page-upload">
        <div class="card">
          <div class="card-header">
            <div class="card-title">📤 上传更新包</div>
          </div>
          <div class="card-body">
            <div class="upload-area" id="uploadArea" onclick="document.getElementById('fileInput').click()">
              <div class="up-icon">📁</div>
              <div class="up-title">点击选择文件，或将 ZIP 拖拽到此</div>
              <div class="up-hint">仅支持 .zip 格式，最大 500 MB</div>
              <div class="file-chosen" id="fileChosen"></div>
            </div>
            <input type="file" id="fileInput" accept=".zip" style="display:none" onchange="handleFileSelect(this)">

            <div class="form-grid">
              <div class="form-item">
                <label>版本号 *</label>
                <input type="text" id="f_version" placeholder="例：1.2.2">
              </div>
              <div class="form-item">
                <label>更新通道</label>
                <select id="f_channel">
                  <option value="stable">稳定版 (stable)</option>
                  <option value="beta">测试版 (beta)</option>
                  <option value="alpha">内测版 (alpha)</option>
                  <option value="dev">开发版 (dev)</option>
                </select>
              </div>
              <div class="form-item">
                <label>平台</label>
                <select id="f_platform">
                  <option value="win">Windows</option>
                  <option value="linux">Linux</option>
                  <option value="macos">macOS</option>
                </select>
              </div>
              <div class="form-item">
                <label>架构</label>
                <select id="f_arch">
                  <option value="x64">x64</option>
                  <option value="arm64">arm64</option>
                </select>
              </div>
              <div class="form-item">
                <label>最低兼容版本</label>
                <input type="text" id="f_minVersion" placeholder="1.0.0" value="1.0.0">
              </div>
              <div class="form-item" style="display:flex;align-items:flex-end;">
                <label class="checkbox-label">
                  <input type="checkbox" id="f_forceUpdate"> 强制更新
                </label>
              </div>
            </div>

            <div class="form-grid" style="grid-template-columns:1fr 1fr;">
              <div class="form-item">
                <label>更新日志（中文）</label>
                <textarea id="f_changelogZh" placeholder="每行一条，例如：&#10;✨ 新增功能&#10;🐛 修复问题"></textarea>
              </div>
              <div class="form-item">
                <label>更新日志（英文）</label>
                <textarea id="f_changelogEn" placeholder="One per line, e.g.:&#10;✨ New feature&#10;🐛 Bug fix"></textarea>
              </div>
            </div>

            <div style="display:flex;gap:10px;margin-top:4px;">
              <button class="btn btn-primary" onclick="uploadPackage()" id="uploadBtn">
                📤 上传更新包
              </button>
            </div>
            <div class="progress-wrap" id="uploadProgress">
              <div class="progress-fill" id="uploadProgressFill"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ─── Packages ─── -->
      <div class="page-section" id="page-packages">
        <div class="card">
          <div class="card-header">
            <div class="card-title">📦 更新包管理</div>
            <button class="btn btn-ghost btn-sm" onclick="loadPackages()">🔄 刷新</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>版本</th>
                  <th>平台 / 架构</th>
                  <th>通道</th>
                  <th>大小</th>
                  <th>下载</th>
                  <th>发布日期</th>
                  <th>状态</th>
                  <th>操作</th>
                </tr>
              </thead>
              <tbody id="packagesTable">
                <tr class="empty-row"><td colspan="9"><span class="empty-icon">⏳</span>加载中…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- ─── Logs ─── -->
      <div class="page-section" id="page-logs">
        <div class="card">
          <div class="card-header">
            <div class="card-title">📋 下载日志</div>
            <button class="btn btn-ghost btn-sm" onclick="loadLogs()">🔄 刷新</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>时间</th>
                  <th>版本</th>
                  <th>平台 / 架构</th>
                  <th>客户端版本</th>
                  <th>IP 地址</th>
                </tr>
              </thead>
              <tbody id="logsTable">
                <tr class="empty-row"><td colspan="5"><span class="empty-icon">⏳</span>加载中…</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /layout -->

<!-- ─── Toast ─── -->
<div class="toast-container" id="toastContainer"></div>

<!-- ─── Delete Modal ─── -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal">
    <h3>⚠️ 确认删除</h3>
    <p id="deleteMsg">确定要删除这个更新包吗？此操作不可恢复。</p>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm" onclick="closeDeleteModal()">取消</button>
      <button class="btn btn-sm" style="background:var(--danger);color:#fff;" onclick="confirmDelete()">确认删除</button>
    </div>
  </div>
</div>

<script>
  const API = '/api';
  let token = localStorage.getItem('token');
  let currentUsername = localStorage.getItem('username') || '管理员';
  let deleteTargetId = null;

  // Auth check
  if (!token) {
    window.location.href = '/login';
  } else {
    document.getElementById('userDisplay').textContent = currentUsername;
  }

  // ─── API helper ───
  function api(method, path, body) {
    const opts = {
      method,
      headers: { 'Authorization': 'Bearer ' + token }
    };
    if (body instanceof FormData) {
      opts.body = body;
    } else if (body) {
      opts.headers['Content-Type'] = 'application/json';
      opts.body = JSON.stringify(body);
    }
    return fetch(API + path, opts).then(async r => {
      if (r.status === 401) { logout(); return {}; }
      return r.json();
    });
  }

  function logout() {
    localStorage.removeItem('token');
    localStorage.removeItem('username');
    window.location.href = '/login';
  }

  // ─── Toast ───
  function toast(msg, type = 'info') {
    const el = document.createElement('div');
    el.className = 'toast toast-' + type;
    el.textContent = msg;
    document.getElementById('toastContainer').appendChild(el);
    setTimeout(() => el.remove(), 3500);
  }

  // ─── Page Switch ───
  const pageTitles = {
    dashboard: '仪表盘',
    upload: '上传更新包',
    packages: '更新包管理',
    logs: '下载日志'
  };

  function switchPage(page, el) {
    document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
    document.getElementById('page-' + page).classList.add('active');
    document.querySelectorAll('.nav-item').forEach(a => a.classList.remove('active'));
    if (el) el.classList.add('active');
    document.getElementById('pageTitle').textContent = pageTitles[page] || page;
    document.getElementById('sidebar').classList.remove('open');

    if (page === 'dashboard') loadDashboard();
    if (page === 'packages') loadPackages();
    if (page === 'logs') loadLogs();
  }

  // ─── Dashboard ───
  async function loadDashboard() {
    try {
      const [statsRes, pkgRes] = await Promise.all([
        api('GET', '/upload/stats'),
        api('GET', '/packages')
      ]);

      if (statsRes.code === 200) {
        const d = statsRes.data;
        document.getElementById('statTotal').textContent = d.totalPackages ?? '0';
        document.getElementById('statDownloads').textContent = d.totalDownloads ?? '0';
        document.getElementById('statRecent').textContent = d.recentDownloads ?? '0';
        const platforms = (d.platformStats || []).map(p => `${p.platform}(${p.count})`).join('  ') || '—';
        document.getElementById('statPlatforms').textContent = platforms;
      }

      if (pkgRes.code === 200) {
        const list = (pkgRes.data || []).slice(0, 6);
        const tbody = document.getElementById('recentTable');
        if (!list.length) {
          tbody.innerHTML = '<tr class="empty-row"><td colspan="7"><span class="empty-icon">📭</span>暂无更新包</td></tr>';
        } else {
          tbody.innerHTML = list.map(p => `
            <tr>
              <td><span class="version-pill">v${p.version}</span></td>
              <td>${p.platform} / ${p.arch}</td>
              <td><span class="badge badge-${p.channel}">${p.channel}</span></td>
              <td>${fmtSize(p.size)}</td>
              <td>${p.download_count || 0}</td>
              <td>${p.release_date}</td>
              <td><span class="badge badge-${p.is_active ? 'active' : 'inactive'}">${p.is_active ? '启用' : '禁用'}</span></td>
            </tr>`).join('');
        }
      }
    } catch (e) {
      toast('加载仪表盘数据失败', 'error');
    }
  }

  // ─── Upload ───
  let selectedFile = null;

  const uploadArea = document.getElementById('uploadArea');
  uploadArea.addEventListener('dragover', e => { e.preventDefault(); uploadArea.classList.add('dragover'); });
  uploadArea.addEventListener('dragleave', () => uploadArea.classList.remove('dragover'));
  uploadArea.addEventListener('drop', e => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    const files = e.dataTransfer.files;
    if (files.length) {
      document.getElementById('fileInput').files = files;
      handleFileSelect(document.getElementById('fileInput'));
    }
  });

  function handleFileSelect(input) {
    const file = input.files[0];
    if (!file) return;
    if (!file.name.endsWith('.zip')) { toast('仅支持 .zip 格式', 'error'); return; }
    selectedFile = file;
    document.getElementById('fileChosen').textContent = '📄 ' + file.name + '  (' + fmtSize(file.size) + ')';
    // Auto-fill version
    const m = file.name.match(/v([\d.]+)/);
    if (m && !document.getElementById('f_version').value) {
      document.getElementById('f_version').value = m[1];
    }
  }

  async function uploadPackage() {
    if (!selectedFile) { toast('请先选择文件', 'error'); return; }
    const version = document.getElementById('f_version').value.trim();
    if (!version || !/^\d+\.\d+\.\d+$/.test(version)) {
      toast('版本号格式错误，应为 x.y.z', 'error');
      return;
    }

    const btn = document.getElementById('uploadBtn');
    const bar = document.getElementById('uploadProgress');
    const fill = document.getElementById('uploadProgressFill');
    btn.disabled = true;
    btn.textContent = '上传中…';
    bar.classList.add('show');
    fill.style.width = '0%';

    try {
      const fd = new FormData();
      fd.append('file', selectedFile);
      fd.append('version', version);
      fd.append('channel', document.getElementById('f_channel').value);
      fd.append('platform', document.getElementById('f_platform').value);
      fd.append('arch', document.getElementById('f_arch').value);
      fd.append('minVersion', document.getElementById('f_minVersion').value || '0.0.0');
      fd.append('forceUpdate', document.getElementById('f_forceUpdate').checked ? 'true' : 'false');
      fd.append('breakingChanges', 'false');

      const czh = document.getElementById('f_changelogZh').value.trim();
      const cen = document.getElementById('f_changelogEn').value.trim();
      if (czh) fd.append('changelogZh', JSON.stringify(czh.split('\n').filter(l => l.trim())));
      if (cen) fd.append('changelogEn', JSON.stringify(cen.split('\n').filter(l => l.trim())));

      // Fake progress
      let p = 0;
      const iv = setInterval(() => {
        p = Math.min(p + Math.random() * 18, 88);
        fill.style.width = p + '%';
      }, 400);

      const res = await fetch(API + '/upload', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: fd
      });
      const data = await res.json();

      clearInterval(iv);
      fill.style.width = '100%';

      if (data.code === 200) {
        toast('✅ 上传成功！v' + data.data.version, 'success');
        selectedFile = null;
        document.getElementById('fileInput').value = '';
        document.getElementById('fileChosen').textContent = '';
        document.getElementById('f_version').value = '';
        document.getElementById('f_changelogZh').value = '';
        document.getElementById('f_changelogEn').value = '';
      } else {
        toast('上传失败：' + data.message, 'error');
      }
    } catch (e) {
      toast('上传失败：' + e.message, 'error');
    }

    setTimeout(() => {
      bar.classList.remove('show');
      fill.style.width = '0%';
      btn.disabled = false;
      btn.innerHTML = '📤 上传更新包';
    }, 1200);
  }

  // ─── Packages ───
  async function loadPackages() {
    const tbody = document.getElementById('packagesTable');
    tbody.innerHTML = '<tr class="empty-row"><td colspan="9"><span class="empty-icon">⏳</span>加载中…</td></tr>';
    try {
      const res = await api('GET', '/packages');
      if (res.code !== 200 || !res.data || !res.data.length) {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="9"><span class="empty-icon">📭</span>暂无更新包</td></tr>';
        return;
      }
      tbody.innerHTML = res.data.map(p => `
        <tr>
          <td style="color:var(--text-muted)">#${p.id}</td>
          <td><span class="version-pill">v${p.version}</span></td>
          <td>${p.platform} / ${p.arch}</td>
          <td><span class="badge badge-${p.channel}">${p.channel}</span></td>
          <td>${fmtSize(p.size)}</td>
          <td>${p.download_count || 0}</td>
          <td>${p.release_date}</td>
          <td><span class="badge badge-${p.is_active ? 'active' : 'inactive'}">${p.is_active ? '启用' : '禁用'}</span></td>
          <td style="white-space:nowrap">
            <button class="btn btn-sm btn-enable-ghost" onclick="togglePackage(${p.id})">${p.is_active ? '禁用' : '启用'}</button>
            <button class="btn btn-sm btn-danger-ghost" onclick="showDeleteModal(${p.id}, 'v${p.version}')">删除</button>
          </td>
        </tr>`).join('');
    } catch (e) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="9"><span class="empty-icon">❌</span>加载失败</td></tr>';
    }
  }

  async function togglePackage(id) {
    try {
      const res = await api('PATCH', '/packages/' + id + '/toggle');
      if (res.code === 200) { toast(res.message, 'success'); loadPackages(); }
      else toast(res.message, 'error');
    } catch { toast('操作失败', 'error'); }
  }

  function showDeleteModal(id, name) {
    deleteTargetId = id;
    document.getElementById('deleteMsg').textContent = `确定要删除更新包 ${name} 吗？此操作不可恢复。`;
    document.getElementById('deleteModal').classList.add('show');
  }
  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.remove('show');
    deleteTargetId = null;
  }
  async function confirmDelete() {
    if (!deleteTargetId) return;
    try {
      const res = await api('DELETE', '/packages/' + deleteTargetId);
      if (res.code === 200) { toast('删除成功', 'success'); closeDeleteModal(); loadPackages(); }
      else toast(res.message, 'error');
    } catch { toast('删除失败', 'error'); }
  }

  // ─── Logs ───
  async function loadLogs() {
    const tbody = document.getElementById('logsTable');
    tbody.innerHTML = '<tr class="empty-row"><td colspan="5"><span class="empty-icon">⏳</span>加载中…</td></tr>';
    try {
      const res = await api('GET', '/upload/logs?limit=50');
      if (res.code !== 200 || !res.data || !res.data.length) {
        tbody.innerHTML = '<tr class="empty-row"><td colspan="5"><span class="empty-icon">📭</span>暂无下载记录</td></tr>';
        return;
      }
      tbody.innerHTML = res.data.map(l => `
        <tr>
          <td style="color:var(--text-muted);font-size:13px">${l.downloaded_at || '—'}</td>
          <td><span class="version-pill">v${l.version || '—'}</span></td>
          <td>${l.platform || '—'} / ${l.arch || '—'}</td>
          <td>${l.client_version || '—'}</td>
          <td style="font-family:monospace;font-size:12px">${l.client_ip || '—'}</td>
        </tr>`).join('');
    } catch {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="5"><span class="empty-icon">❌</span>加载失败</td></tr>';
    }
  }

  // ─── Utils ───
  function fmtSize(bytes) {
    if (!bytes) return '—';
    const u = ['B', 'KB', 'MB', 'GB'];
    let i = 0;
    while (bytes >= 1024 && i < u.length - 1) { bytes /= 1024; i++; }
    return bytes.toFixed(1) + ' ' + u[i];
  }

  // Close modal on overlay click
  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
  });

  // ─── Init ───
  loadDashboard();
</script>
</body>
</html>
