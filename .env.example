# MuYunAPI 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ── 通用 ────────────────────────────────────────────────────────────────────
# JWT 密钥（建议32位以上随机字符串，主服务 + 更新服务器请保持一致）
JWT_SECRET=your_super_secret_jwt_key_here

# 热重载共享密钥（主服务通知更新服务器重启时使用，主服务 + 更新服务器请保持一致）
UPDATE_SECRET=change_me_to_a_random_secret

# ── 主服务 (server/) ─────────────────────────────────────────────────────────
# 管理员账号（系统首次启动时自动创建）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourSecurePassword123

# 内部更新服务器地址（主服务向更新服务器发热重载信号时使用）
# Windows 本机：默认 http://localhost:3001
# Linux 服务器：若更新服务器也在本机则同上；若在另一台机器请填实际 IP
INTERNAL_UPDATE_SERVER_URL=http://localhost:3001

# SMTP邮件配置（用于发送验证码等）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_email_password
SMTP_FROM=MuYunAPI <noreply@example.com>

# API代理密钥（用于调用外部API）
PROXY_API_KEY=your_proxy_api_key_here
